# Add your keys here later. The app runs in offline demo mode without them.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Search providers. Tavily is implemented first; Serper/Firecrawl keys are reserved.
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# Optional observability / memory
LANGSMITH_API_KEY=
CHROMA_PATH=.chroma

# Runtime
MAX_ITERATIONS=3
SEARCH_RESULTS_PER_QUERY=5
DEFAULT_LLM_PROVIDER=openai
